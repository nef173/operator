# ── Operator API environment ───────────────────────────────────────────────
# Copy to .env for local dev (never commit .env). On Railway set these as service
# variables in the dashboard instead of a file.

# Persistence. UNSET locally → SQLite at api/data/app.db (fine for dev). On Railway set
# this to your Neon Postgres URL so jobs/runs/decisions/settings survive a redeploy
# (Railway's filesystem is ephemeral — a deploy wipes SQLite). Use Neon's POOLED
# connection string (host has "-pooler") so the connection pool stays within Neon's free
# budget. The Postgres adapter (app/db.py) turns on automatically when this is set.
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Max DB connections the pool will open (keep small on Neon free). Default 5.
# DB_POOL_MAX=5

# Path to the Google Stores pipeline checkout the backend reads from. Defaults to the repo
# this app lives in. When the API is deployed standalone (no pipeline files alongside it),
# the control layer (jobs/decisions/settings/connections/worker) still works; research/
# listing views read empty until a pipeline snapshot is provided.
# GOOGLE_STORES_ROOT=/abs/path/to/Google Stores

# Comma-separated origins allowed to call the API (the Next.js frontend). Set this to your
# deployed web URL on Railway, e.g. https://operator-web-production.up.railway.app
CORS_ORIGINS=http://localhost:3000

# Concurrency knob for in-app auto jobs (background thread pool). Default 3.
# OPERATOR_JOB_WORKERS=3
